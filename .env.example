# Shared runtime model configuration for the benchmark.
# Edit only these values to switch between a local OpenAI-compatible server and OpenAI API.

OPENAI_BASE_URL=http://127.0.0.1:8080/v1
OPENAI_EMBEDDING_BASE_URL=http://127.0.0.1:8010/v1
OPENAI_API_KEY=local
OPENAI_MODEL=/models/Qwen3.5-35B-A3B-Q4_K_M.gguf
OPENAI_EMBEDDING_MODEL=multilingual-e5-large

# Example OpenAI API values:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=your-openai-key
# OPENAI_MODEL=gpt-5-nano
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
