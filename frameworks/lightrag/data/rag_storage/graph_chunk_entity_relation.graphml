  <data key="d7">1.0</data>
  <data key="d8">Пункт «Минимизировать Ленту» доступен через контекстное меню панели.</data>
  <data key="d9">действие,доступ</data>
  <data key="d10">doc-b430a0e1bfb4f4afd1e462c83fa3654c-chunk-017</data>
  <data key="d11">D0.txt</data>
  <data key="d12">1783956582</data>
  <data key="d13"></data>
</edge>
<edge source="Контекстное меню" target="Лента">
  <data key="d7">1.0</data>
  <data key="d8">Контекстное меню вызывается в области панели «Лента» для управления её состоянием.</data>
  <data key="d9">интерфейс,управление</data>
  <data key="d10">doc-b430a0e1bfb4f4afd1e462c83fa3654c-chunk-017</data>
  <data key="d11">D0.txt</data>
  <data key="d12">1783956582</data>
  <data key="d13"></data>
</edge>
<edge source="Контекстное меню" target="Удаление объектов модели">
  <data key="d7">1.0</data>
  <data key="d8">Процедура удаления объектов модели инициируется через команду контекстного меню «Удалить», вызываемую нажатием правой кнопки мыши.</data>
  <data key="d9">интерфейс,удаление</data>
  <data key="d10">doc-b430a0e1bfb4f4afd1e462c83fa3654c-chunk-035</data>
  <data key="d11">D0.txt</data>
