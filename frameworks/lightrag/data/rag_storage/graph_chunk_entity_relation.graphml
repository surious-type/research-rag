  <data key="d12">1783956582</data>
  <data key="d13"></data>
</edge>
<edge source="Навигатор модели" target="Красная звёздочка">
  <data key="d7">1.0</data>
  <data key="d8">Параметр «Имя» помечается красной звёздочкой в интерфейсе до подтверждения изменений.</data>
  <data key="d9">индикация,интерфейс,статус</data>
