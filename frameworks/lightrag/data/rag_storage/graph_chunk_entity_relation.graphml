  <data key="d13"></data>
</edge>
<edge source="Навигатор модели" target="Колонка">
  <data key="d7">1.0</data>
  <data key="d8">Навигатор модели позволяет управлять видимостью колонок через пиктограммы и флаги.</data>
  <data key="d9">интерфейс,управление видимостью</data>
