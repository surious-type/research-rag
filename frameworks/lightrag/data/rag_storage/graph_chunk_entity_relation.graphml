  <data key="d13"></data>
</edge>
<edge source="Свойства документа" target="Тип документа">
  <data key="d7">1.0</data>
  <data key="d8">Тип документа (деталь, чертеж и т.д.) является ключевой характеристикой активного документа.</data>
  <data key="d9">классификация,назначение</data>
