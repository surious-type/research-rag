<edge source="Навигатор модели" target="Операция">
  <data key="d7">1.0</data>
  <data key="d8">Через Навигатор модели можно выбрать операцию, открыть контекстное меню и запустить диалог для её редактирования.</data>
  <data key="d9">редактирование,управление</data>
