  <data key="d11">D0.txt</data>
  <data key="d12">1783956582</data>
  <data key="d13"></data>
</edge>
<edge source="Навигатор модели" target="Имя">
  <data key="d7">1.0</data>
  <data key="d8">Параметр «Имя» используется для идентификации объекта и поиска его в навигаторе.</data>
  <data key="d9">идентификация,параметр,поиск</data>
