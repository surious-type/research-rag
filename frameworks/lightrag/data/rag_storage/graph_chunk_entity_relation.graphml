  <data key="d13"></data>
</edge>
<edge source="Меню Файл" target="Панель Лента">
  <data key="d7">1.0</data>
  <data key="d8">При выборе атрибута через меню «Файл» активируется соответствующая вкладка на панели «Лента».</data>
  <data key="d9">активация,вкладка,интерфейс</data>
