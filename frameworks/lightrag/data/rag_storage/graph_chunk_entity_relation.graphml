  <data key="d11">D0.txt</data>
  <data key="d12">1783956582</data>
  <data key="d13"></data>
</edge>
<edge source="Навигатор модели" target="Объект">
  <data key="d7">1.0</data>
  <data key="d8">Через Навигатор модели можно выбрать объект и отредактировать его параметры.</data>
  <data key="d9">редактирование,управление</data>
  <data key="d10">doc-b430a0e1bfb4f4afd1e462c83fa3654c-chunk-040</data>
  <data key="d11">D0.txt</data>
  <data key="d12">1783956582</data>
  <data key="d13"></data>
