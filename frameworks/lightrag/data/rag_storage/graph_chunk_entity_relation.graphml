  <data key="d12">1783956582</data>
  <data key="d13"></data>
</edge>
<edge source="Навигатор модели" target="Абсолютная СК документа">
  <data key="d7">1.0</data>
  <data key="d8">Положение объекта-копии при вставке сохраняется относительно абсолютной системы координат документа, отображаемой в навигаторе.</data>
  <data key="d9">координаты,позиционирование</data>
