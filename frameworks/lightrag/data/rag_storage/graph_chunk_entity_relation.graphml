  <data key="d7">1.0</data>
  <data key="d8">Нажатие пиктограммы зависимостей раскрывает цепочку зависимостей, отображаемую в виде дерева зависимостей.</data>
  <data key="d9">визуализация,раскрытие,управление</data>
