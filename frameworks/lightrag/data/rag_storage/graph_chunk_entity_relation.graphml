<edge source="Контекстное меню" target="Панель быстрого доступа">
  <data key="d7">1.0</data>
  <data key="d8">Контекстное меню используется для вызова окна настройки состава и ориентации панели быстрого доступа.</data>
  <data key="d9">настройка,ориентация,состав</data>
