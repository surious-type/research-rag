  <data key="d12">1783956582</data>
  <data key="d13"></data>
</edge>
<edge source="Левая кнопка мыши" target="Контекстная панель кнопок">
  <data key="d7">1.0</data>
  <data key="d8">Контекстная панель кнопок активируется действием левой кнопки мыши по объектам.</data>
  <data key="d9">активация,выбор,действие</data>
