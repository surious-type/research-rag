  <data key="d12">1783956582</data>
  <data key="d13"></data>
</edge>
<edge source="Интегрированные модули" target="Кнопка Добавить">
  <data key="d7">1.0</data>
  <data key="d8">С помощью кнопки Добавить осуществляется интеграция модуля в систему.</data>
  <data key="d9">добавление,интеграция</data>
  <data key="d10">doc-b430a0e1bfb4f4afd1e462c83fa3654c-chunk-001</data>
  <data key="d11">D0.txt</data>
  <data key="d12">1783956582</data>
  <data key="d13"></data>
</edge>
<edge source="Интегрированные модули" target="Кнопка Удалить">
  <data key="d7">1.0</data>
  <data key="d8">С помощью кнопки Удалить осуществляется отключение выбранного модуля из перечня подключенных.</data>
  <data key="d9">отключение,удаление</data>
  <data key="d10">doc-b430a0e1bfb4f4afd1e462c83fa3654c-chunk-001</data>
  <data key="d11">D0.txt</data>
  <data key="d12">1783956582</data>
  <data key="d13"></data>
