PORT=19621

WEBUI_TITLE='Smoke LightRAG'
WEBUI_DESCRIPTION='Isolated LightRAG smoke test'

SUMMARY_LANGUAGE=Russian
VLM_PROCESS_ENABLE=false

ENTITY_EXTRACTION_USE_JSON=true
LIGHTRAG_PARSER=*:legacy-R

CHUNK_SIZE=450
CHUNK_OVERLAP_SIZE=50
MAX_PARALLEL_INSERT=1

LLM_BINDING=openai
LLM_BINDING_HOST=http://host.docker.internal:8080/v1
LLM_BINDING_API_KEY=dummy
LLM_MODEL=/models/Qwen3.5-35B-A3B-Q4_K_M.gguf
LLM_TIMEOUT=600
MAX_ASYNC_LLM=1
OPENAI_LLM_TEMPERATURE=0.1
OPENAI_LLM_MAX_TOKENS=8000

EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=http://host.docker.internal:8010/v1
EMBEDDING_BINDING_API_KEY=dummy
EMBEDDING_MODEL=multilingual-e5-large
EMBEDDING_DIM=1024
EMBEDDING_TOKEN_LIMIT=512
EMBEDDING_TIMEOUT=120
EMBEDDING_SEND_DIM=false
EMBEDDING_USE_BASE64=false
EMBEDDING_BATCH_NUM=8

EMBEDDING_ASYMMETRIC=true
EMBEDDING_DOCUMENT_PREFIX="passage: "
EMBEDDING_QUERY_PREFIX="query: "

LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage

RERANK_BINDING=null
RERANK_BY_DEFAULT=false
